# Database driver: sqlite or postgres
DB_DRIVER=postgres

# SQLite mode
# DB_PATH=/absolute/path/to/tieba.sqlite

# Postgres mode
DATABASE_URL=postgresql://user:password@localhost:5432/tieba

# Comma-separated base directories that contain by_prefix/...
IMAGE_BASE_DIRS=/path/to/images/output1,/path/to/images/output2
